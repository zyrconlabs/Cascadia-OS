# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# License Signing Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
LICENSE_SIGNING_SECRET=generate-a-random-64-char-hex-string

# Email Configuration (optional - for sending license keys)
SENDGRID_API_KEY=SG....

# Cascadia OS Configuration
CASCADIA_INFERENCE_URL=http://localhost:8080

# VAULT encryption key (generate with: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())")
# Without this key, VAULT stores values as plaintext JSON. Set before first write in production.
VAULT_ENCRYPTION_KEY=

# ── Memory Governor (skeleton, all default false) ───────────────────────────
MEMORY_GOVERNOR_ENABLED=false
OUTBOX_ENABLED=false
RAM_LOG_BUFFER_ENABLED=false
MISSION_COMPACTION_ENABLED=false
