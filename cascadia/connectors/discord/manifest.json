{
  "id": "discord-connector",
  "name": "Discord Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "Send messages to Discord channels via bot token.",
  "author": "Zyrcon Labs",
  "price": 0,
  "tier_required": "lite",
  "port": 9004,
  "entry_point": "connector.py",
  "dependencies": [
    "nats-py"
  ],
  "install_hook": "install.sh",
  "uninstall_hook": "uninstall.sh",
  "category": "communication",
  "industries": [
    "all"
  ],
  "installed_by_default": false,
  "safe_to_uninstall": true,
  "auth_type": "bearer",
  "nats_subjects": [
    "cascadia.connectors.discord-connector.>"
  ],
  "risk_level": "high",
  "permissions": [
    "send_message",
    "read_channel"
  ],
  "requires_approval_for": [
    "message.send"
  ],
  "data_access": [
    "message_content",
    "guild_members"
  ],
  "writes_external_systems": true,
  "network_access": true,
  "setup_fields": [
    {
      "name": "bot_token",
      "label": "Discord Bot Token",
      "type": "secret",
      "required": true,
      "secret": true,
      "vault_key": "discord:bot_token",
      "simple_mode": true,
      "help_text": "From your Discord Developer Portal under Bot > Token"
    },
    {
      "name": "approval_before_send",
      "label": "Require approval before sending messages",
      "type": "boolean",
      "required": false,
      "default": true,
      "simple_mode": true,
      "help_text": "Always approve before operators send Discord messages"
    }
  ]
}
