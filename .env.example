# Test fixture secret for TierValidator tests (NOT a real secret — override in CI if needed)
TEST_LICENSE_SECRET=test-fixture-not-real-aaaa1111bbbb2222cccc3333dddd4444eeff0011223344556677889900aabbcc

# Email Configuration (optional - for sending license keys)
