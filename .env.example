# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# License Signing Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
