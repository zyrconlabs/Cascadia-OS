{
  "id": "google-connector",
  "name": "Google Accounts Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "OAuth2 identity and account access for Google services. Manages the full auth flow and token lifecycle for Gmail, Calendar, and Drive connectors.",
  "author": "Zyrcon Labs",
  "price": 0,
  "tier_required": "pro",
  "port": 9020,
  "entry_point": "connector.py",
  "dependencies": ["nats-py"],
  "install_hook": "install.sh",
  "uninstall_hook": "uninstall.sh",
  "category": "identity",
  "industries": ["all"],
  "installed_by_default": false,
  "safe_to_uninstall": false,
  "auth_type": "oauth2",
  "approval_required_for_writes": true,
  "nats_subjects": ["cascadia.connectors.google-connector.>"],
  "setup_required": true,
  "setup_instructions": "Create OAuth2 credentials at console.cloud.google.com. Set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET env vars.",
  "risk_level": "medium",
  "permissions": ["read_google_profile", "manage_oauth2_tokens"],
  "requires_approval_for": ["revoke_token"],
  "data_access": ["google_account_profile", "oauth2_tokens"],
  "writes_external_systems": false,
  "network_access": true
}
